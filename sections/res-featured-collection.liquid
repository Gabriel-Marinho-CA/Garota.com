{{ 'res-featured-collection.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

{% liquid
  assign autoplay = section.settings.autoplay
  assign autoplay_time = section.settings.autoplay_time | times: 1000
  assign show_button = section.settings.show_button
  assign add_to_cart = section.settings.add_to_cart
  assign show_installments = section.settings.show_installments
  assign tab_blocks = section.blocks | where: 'type', 'collection_tab'
%}

{% style %}
  .{{ section.id }} {
    display: block;
    {% if section.settings.background_type == 'image' and section.settings.background_image_mobile != blank %}
      background-image: url('{{ section.settings.background_image_mobile | image_url }}');
    {% elsif section.settings.background_type == 'color' and section.settings.background_color != blank %}
      background: {{ section.settings.background_color }};
    {% elsif section.settings.background_type == 'gradient' and section.settings.background_gradient != blank %}
      background: {{ section.settings.background_gradient }};
    {% endif %}
    padding-top: {{ section.settings.pad_top_mobile }}px;
    padding-bottom: {{ section.settings.pad_bottom_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .{{ section.id }} {
      {% if section.settings.background_type == 'image' and section.settings.background_image_desktop != blank %}
        background-image: url('{{ section.settings.background_image_desktop | image_url }}');
      {% endif %}
      padding-top: {{ section.settings.pad_top_desktop }}px;
      padding-bottom: {{ section.settings.pad_bottom_desktop }}px;
    }
  }

  {% if section.settings.title_custom %}
    .{{ section.id }} .res-fc__title {
      {% if section.settings.title_color != blank %}color: {{ section.settings.title_color }};{% endif %}
      {% if section.settings.title_font_size_mobile > 0 %}font-size: {{ section.settings.title_font_size_mobile }}px;{% endif %}
      {% if section.settings.title_font_weight != blank %}font-weight: {{ section.settings.title_font_weight }};{% endif %}
    }
    {% if section.settings.title_font_size_desktop > 0 %}
      @media screen and (min-width: 750px) {
        .{{ section.id }} .res-fc__title { font-size: {{ section.settings.title_font_size_desktop }}px; }
      }
    {% endif %}
  {% endif %}

  {% if section.settings.tab_color != blank %}
    .{{ section.id }} .res-fc__tab { color: {{ section.settings.tab_color }}; border-color: {{ section.settings.tab_color }}; }
  {% endif %}
  {% if section.settings.tab_active_bg != blank %}
    .{{ section.id }} .res-fc__tab--active { background-color: {{ section.settings.tab_active_bg }}; border-color: {{ section.settings.tab_active_bg }}; }
  {% endif %}
  {% if section.settings.tab_active_color != blank %}
    .{{ section.id }} .res-fc__tab--active { color: {{ section.settings.tab_active_color }}; }
  {% endif %}
{% endstyle %}

<res-featured-collection
  class="res-fc {{ section.id }} scroll-trigger animate--fade-in"
  data-autoplay="{{ autoplay }}"
  data-autoplay-time="{{ autoplay_time }}"
  data-two-rows="{{ section.settings.two_rows }}"
  data-center-insufficient="true"
>
  <div class="res-fc__wrapper page-width">

    {%- comment -%} Titulo {%- endcomment -%}
    {% if section.settings.title != blank %}
      <div class="res-fc__header">
        <h2 class="res-fc__title">{{ section.settings.title | escape }}</h2>
      </div>
    {% endif %}

    {%- comment -%} Tabs {%- endcomment -%}
    {% if tab_blocks.size > 0 %}
      <div class="wrapper">
              <div class="res-fc__tabs">
        {% for block in tab_blocks %}
          <button
            class="res-fc__tab{% if forloop.first %} res-fc__tab--active{% endif %}"
            data-tab-index="{{ forloop.index0 }}"
            type="button"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.tab_name | escape }}
          </button>
        {% endfor %}
      </div>
      </div>

    {% endif %}

    {%- comment -%} Carousel com setas fora {%- endcomment -%}
    <div class="res-fc__carousel">
      <button class="res-fc__nav res-fc__nav--prev" aria-label="Anterior">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="res-fc__slider-area">
        {% for block in tab_blocks %}
          {%- assign products = block.settings.collection.products -%}
          <div
            class="res-fc__tab-panel{% if forloop.first %} res-fc__tab-panel--active{% endif %}"
            data-tab-index="{{ forloop.index0 }}"
          >
            <div class="swiper res-fc__swiper">
              <div class="swiper-wrapper">
                {% if products != blank %}
                  {% for product in products %}
                    <div class="swiper-slide">
                      {% render 'res-product-card',
                        res_product: product,
                        show_price: true,
                        show_button: show_button,
                        add_to_cart: add_to_cart,
                        show_installments: show_installments
                      %}
                    </div>
                  {% endfor %}
                {% else %}
                  {% for i in (1..4) %}
                    <div class="swiper-slide">
                      {% render 'res-product-card',
                        show_price: true,
                        show_button: show_button,
                        show_installments: show_installments
                      %}
                    </div>
                  {% endfor %}
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}

        {%- comment -%} Fallback: nenhum block adicionado {%- endcomment -%}
        {% if tab_blocks.size == 0 %}
          <div class="res-fc__tab-panel res-fc__tab-panel--active" data-tab-index="0">
            <div class="swiper res-fc__swiper">
              <div class="swiper-wrapper">
                {% for i in (1..4) %}
                  <div class="swiper-slide">
                    {% render 'res-product-card',
                      show_price: true,
                      show_button: show_button,
                      show_installments: show_installments
                    %}
                  </div>
                {% endfor %}
              </div>
            </div>
          </div>
        {% endif %}
      </div>

      <button class="res-fc__nav res-fc__nav--next" aria-label="Próximo">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    {%- comment -%} Botao "Ver mais" mobile {%- endcomment -%}
    {% if section.settings.view_more_text != blank %}
      <a class="res-fc__view-more res-fc__view-more--mobile" href="{{ section.settings.view_more_url }}">
        {{ section.settings.view_more_text | escape }}
      </a>
    {% endif %}
  </div>
</res-featured-collection>

<script>
  (function () {
    class ResFeaturedCollection extends HTMLElement {
      connectedCallback() {
        if ('IntersectionObserver' in window) {
          const io = new IntersectionObserver((entries) => {
            if (entries[0].isIntersecting) {
              io.disconnect();
              this._init();
            }
          }, { threshold: 0 });
          io.observe(this);
        } else {
          requestAnimationFrame(() => this._init());
        }
      }

      disconnectedCallback() {
        this._destroySwipers();
      }

      _destroySwipers() {
        if (this._swipers) {
          this._swipers.forEach(s => s && s.destroy(true, true));
          this._swipers = [];
        }
      }

      _init() {
        this._destroySwipers();

        const autoplay            = this.dataset.autoplay === 'true';
        const autoplayMs          = parseInt(this.dataset.autoplayTime) || 3000;
        const twoRows             = this.dataset.twoRows === 'true';
        const centerInsufficient  = this.dataset.centerInsufficient === 'true';
        const prevEl     = this.querySelector('.res-fc__nav--prev');
        const nextEl     = this.querySelector('.res-fc__nav--next');
        const panels     = this.querySelectorAll('.res-fc__tab-panel');
        const tabs       = this.querySelectorAll('.res-fc__tab');

        this._swipers = [];
        this._activeIndex = 0;

        panels.forEach((panel, i) => {
          const swiperEl = panel.querySelector('.res-fc__swiper');
          if (!swiperEl) return;

          let config;
          if (twoRows) {
            config = {
              slidesPerView: 1.2,
              spaceBetween: 12,
              observer: true,
              observeParents: true,
              centerInsufficientSlides: centerInsufficient,
              breakpoints: {
                750: { slidesPerView: 2, spaceBetween: 16, grid: { rows: 2, fill: 'row' } },
                1024: { slidesPerView: 4, spaceBetween: 20, grid: { rows: 2, fill: 'row' } }
              }
            };
          } else {
            config = {
              slidesPerView: 1.2,
              spaceBetween: 12,
              observer: true,
              observeParents: true,
              centerInsufficientSlides: centerInsufficient,
              breakpoints: {
                750: { slidesPerView: 2, spaceBetween: 16 },
                1024: { slidesPerView: 4, spaceBetween: 20 }
              }
            };
          }

          if (autoplay) {
            config.autoplay = { delay: autoplayMs, disableOnInteraction: false };
          }

          const swiper = new Swiper(swiperEl, config);
          this._swipers.push(swiper);
        });

        /* Nav buttons -> active swiper */
        if (prevEl) {
          prevEl.addEventListener('click', () => {
            const s = this._swipers[this._activeIndex];
            if (s) s.slidePrev();
          });
        }
        if (nextEl) {
          nextEl.addEventListener('click', () => {
            const s = this._swipers[this._activeIndex];
            if (s) s.slideNext();
          });
        }

        /* Tab switching */
        tabs.forEach((tab) => {
          tab.addEventListener('click', () => {
            const idx = parseInt(tab.dataset.tabIndex);
            if (idx === this._activeIndex) return;

            /* Update tab active state */
            tabs.forEach(t => t.classList.remove('res-fc__tab--active'));
            tab.classList.add('res-fc__tab--active');

            /* Switch panel */
            panels.forEach(p => p.classList.remove('res-fc__tab-panel--active'));
            panels[idx].classList.add('res-fc__tab-panel--active');

            this._activeIndex = idx;

            /* Update the newly visible swiper */
            const s = this._swipers[idx];
            if (s) {
              s.update();
              s.slideTo(0, 0);
            }
          });
        });

        /* Initial update */
        setTimeout(() => {
          const s = this._swipers[this._activeIndex];
          if (s) s.update();
        }, 150);
      }
    }

    if (!customElements.get('res-featured-collection')) {
      customElements.define('res-featured-collection', ResFeaturedCollection);
    }
  })();
</script>

{% schema %}
{
  "name": "Vitrine Result",
  "class": "RES__FEATURED_COLLECTION__V1",
  "max_blocks": 10,
  "settings": [
    {
      "type": "header",
      "content": "Conteúdo"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "COMPRE POR CATEGORIA"
    },
    {
      "type": "text",
      "id": "view_more_text",
      "label": "Texto do botão \"Ver mais\""
    },
    {
      "type": "url",
      "id": "view_more_url",
      "label": "Link do botão"
    },
    {
      "type": "header",
      "content": "Cartão de Produto"
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Exibir botão no card",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "add_to_cart",
      "label": "Adicionar ao carrinho",
      "default": false,
      "visible_if": "{{ section.settings.show_button }}"
    },
    {
      "type": "checkbox",
      "id": "show_installments",
      "label": "Exibir parcelas",
      "default": true
    },
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "checkbox",
      "id": "two_rows",
      "label": "Exibir 2 linhas",
      "default": false,
      "info": "Ativo: 2 linhas de produtos. Inativo: 1 linha."
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_time",
      "label": "Tempo",
      "default": 4,
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "visible_if": "{{ section.settings.autoplay }}"
    },
    {
      "type": "header",
      "content": "Tabs"
    },
    {
      "type": "color",
      "id": "tab_color",
      "label": "Cor do texto/borda da tab",
      "default": "#1B1B1B"
    },
    {
      "type": "color",
      "id": "tab_active_bg",
      "label": "Fundo da tab ativa",
      "default": "#1B1B1B"
    },
    {
      "type": "color",
      "id": "tab_active_color",
      "label": "Cor do texto da tab ativa",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Aparência"
    },
    {
      "type": "select",
      "id": "background_type",
      "label": "Tipo de fundo",
      "default": "color",
      "options": [
        { "label": "Cor", "value": "color" },
        { "label": "Gradiente", "value": "gradient" },
        { "label": "Imagem", "value": "image" }
      ]
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Cor",
      "default": "#FFFFFF",
      "visible_if": "{{ section.settings.background_type == 'color' }}"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Gradiente",
      "visible_if": "{{ section.settings.background_type == 'gradient' }}"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Imagem (mobile)",
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "image_picker",
      "id": "background_image_desktop",
      "label": "Imagem (desktop)",
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "header",
      "content": "Tipografia"
    },
    {
      "type": "checkbox",
      "id": "title_custom",
      "label": "Personalizar título",
      "default": false
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Cor",
      "visible_if": "{{ section.settings.title_custom }}"
    },
    {
      "type": "range",
      "id": "title_font_size_desktop",
      "label": "Tamanho (desktop)",
      "min": 16,
      "max": 72,
      "step": 1,
      "default": 36,
      "unit": "px",
      "visible_if": "{{ section.settings.title_custom }}"
    },
    {
      "type": "range",
      "id": "title_font_size_mobile",
      "label": "Tamanho (mobile)",
      "min": 16,
      "max": 48,
      "step": 1,
      "default": 24,
      "unit": "px",
      "visible_if": "{{ section.settings.title_custom }}"
    },
    {
      "type": "select",
      "id": "title_font_weight",
      "label": "Peso",
      "default": "700",
      "options": [
        { "label": "Regular (400)", "value": "400" },
        { "label": "Médio (500)", "value": "500" },
        { "label": "Semi Bold (600)", "value": "600" },
        { "label": "Bold (700)", "value": "700" }
      ],
      "visible_if": "{{ section.settings.title_custom }}"
    },
    {
      "type": "header",
      "content": "Espaçamento"
    },
    {
      "type": "range",
      "id": "pad_top_mobile",
      "label": "Padding TOP (mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "pad_bottom_mobile",
      "label": "Padding BOTTOM (mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "pad_top_desktop",
      "label": "Padding TOP (desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "pad_bottom_desktop",
      "label": "Padding BOTTOM (desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 96,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "collection_tab",
      "name": "Aba de Coleção",
      "settings": [
        {
          "type": "text",
          "id": "tab_name",
          "label": "Nome da aba",
          "default": "Coleção"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Coleção"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Vitrine Result",
      "category": "Coleção",
      "settings": {
        "title": "COMPRE POR CATEGORIA",
        "background_type": "color",
        "background_color": "#FFFFFF",
        "show_button": false,
        "show_installments": true,
        "two_rows": false
      },
      "blocks": [
        { "type": "collection_tab", "settings": { "tab_name": "VESTIDOS" } },
        { "type": "collection_tab", "settings": { "tab_name": "CONJUNTOS" } },
        { "type": "collection_tab", "settings": { "tab_name": "SALE" } },
        { "type": "collection_tab", "settings": { "tab_name": "TOPS" } }
      ]
    }
  ]
}
{% endschema %}
