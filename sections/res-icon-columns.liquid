{{ 'res-icon-columns.css' | asset_url | stylesheet_tag }}

{% style %}
  .{{ section.id }} {
    --res-ic-columns-mobile: {{ section.settings.columns_mobile }};
    --res-ic-columns-desktop: {{ section.settings.columns_desktop }};
    --res-ic-gap-mobile: {{ section.settings.gap_mobile }}px;
    --res-ic-gap-desktop: {{ section.settings.gap_desktop }}px;
    padding-top: {{ section.settings.pad_top_mobile }}px;
    padding-bottom: {{ section.settings.pad_bottom_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .{{ section.id }} {
      padding-top: {{ section.settings.pad_top_desktop }}px;
      padding-bottom: {{ section.settings.pad_bottom_desktop }}px;
    }
  }
{% endstyle %}

<div class="res-ic {{ section.id }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
  <div class="res-ic__wrapper page-width">
    <div class="res-ic__grid">
      {% for block in section.blocks %}
        {% liquid
          assign has_link = false
          if block.settings.url != blank
            assign has_link = true
          endif
          assign icon_alt = block.settings.title | strip_html
        %}
        {% if has_link %}
          <a class="res-ic__item" href="{{ block.settings.url }}" {{ block.shopify_attributes }}>
        {% else %}
          <div class="res-ic__item" {{ block.shopify_attributes }}>
        {% endif %}
          {% if block.settings.icon != blank %}
            <span
              class="res-ic__icon"
              style="--res-ic-icon-size-mobile: {{ block.settings.icon_size_mobile }}px; --res-ic-icon-size-desktop: {{ block.settings.icon_size_desktop }}px;"
            >
              {{ block.settings.icon | image_url: width: 200 | image_tag: alt: icon_alt }}
            </span>
          {% endif %}
          {% if block.settings.title != blank %}
            <div
              class="res-ic__title rte"
              {% if block.settings.title_custom %}
                style="
                  {% if block.settings.title_color != blank %}--res-ic-title-color: {{ block.settings.title_color }};{% endif %}
                  --res-ic-title-weight: {{ block.settings.title_font_weight }};
                  --res-ic-title-align: {{ block.settings.title_align }};
                  --res-ic-title-size-mobile: {{ block.settings.title_font_size_mobile }}px;
                  --res-ic-title-size-desktop: {{ block.settings.title_font_size_desktop }}px;
                "
              {% endif %}
            >
              {{ block.settings.title }}
            </div>
          {% endif %}
          {% if block.settings.text != blank %}
            <div
              class="res-ic__text rte"
              {% if block.settings.text_custom %}
                style="
                  {% if block.settings.text_color != blank %}--res-ic-text-color: {{ block.settings.text_color }};{% endif %}
                  --res-ic-text-weight: {{ block.settings.text_font_weight }};
                  --res-ic-text-align: {{ block.settings.text_align }};
                  --res-ic-text-size-mobile: {{ block.settings.text_font_size_mobile }}px;
                  --res-ic-text-size-desktop: {{ block.settings.text_font_size_desktop }}px;
                "
              {% endif %}
            >
              {{ block.settings.text }}
            </div>
          {% endif %}
        {% if has_link %}
          </a>
        {% else %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
