{{ 'res-wishlist.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

{% liquid
  assign cols_desktop = section.settings.columns_desktop
  assign cols_tablet = section.settings.columns_tablet
  assign cols_mobile = section.settings.columns_mobile
%}

{% style %}
  #shopify-section-{{ section.id }} {
    --res-wl-cols-desktop: {{ cols_desktop }};
    --res-wl-cols-tablet: {{ cols_tablet }};
    --res-wl-cols-mobile: {{ cols_mobile }};
    padding-top: {{ section.settings.pad_top_mobile }}px;
    padding-bottom: {{ section.settings.pad_bottom_mobile }}px;
  }

  @media screen and (min-width: 990px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.pad_top_desktop }}px;
      padding-bottom: {{ section.settings.pad_bottom_desktop }}px;
    }
  }
{% endstyle %}

<res-wishlist class="res-wl page-width" data-card-section="res-wishlist-card">
  {% if section.settings.title != blank %}
    <div class="res-wl__header">
      <h2 class="res-wl__title">
        {{ section.settings.title | escape }}
        <span class="res-wl__count" data-wishlist-count></span>
      </h2>
    </div>
  {% endif %}

  {%- comment -%} Estado: carregando {%- endcomment -%}
  <div class="res-wl__loading" data-wishlist-loading hidden>
    {%- render 'loading-spinner', class: 'loading__spinner' -%}
  </div>

  {%- comment -%} Estado: vazio {%- endcomment -%}
  <div class="res-wl__empty" data-wishlist-empty hidden>
    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
    </svg>
    <p class="res-wl__empty-text">{{ section.settings.empty_text | escape }}</p>
    {% if section.settings.empty_link_text != blank %}
      <a class="res-wl__empty-link button" href="{{ section.settings.empty_link_url | default: routes.all_products_collection_url }}">
        {{ section.settings.empty_link_text | escape }}
      </a>
    {% endif %}
  </div>

  {%- comment -%} Grid de cards (preenchido pelo JS) {%- endcomment -%}
  <div class="res-wl__grid" data-wishlist-grid></div>
</res-wishlist>

<script>
  (function () {
    if (customElements.get('res-wishlist')) return;

    class ResWishlist extends HTMLElement {
      connectedCallback() {
        this.cardSection = this.dataset.cardSection;
        this.grid     = this.querySelector('[data-wishlist-grid]');
        this.empty    = this.querySelector('[data-wishlist-empty]');
        this.loading  = this.querySelector('[data-wishlist-loading]');
        this.countEls = this.querySelectorAll('[data-wishlist-count]');
        this._cards   = new Map(); // id -> wrapper element

        this._onChange = this.render.bind(this);
        window.addEventListener('wishlist:change', this._onChange);

        // WishlistStore vem de wishlist.js (carregado no theme.liquid).
        if (window.WishlistStore) {
          this.render();
        } else {
          window.addEventListener('DOMContentLoaded', () => this.render(), { once: true });
        }
      }

      disconnectedCallback() {
        window.removeEventListener('wishlist:change', this._onChange);
      }

      _store() {
        return window.WishlistStore || null;
      }

      _setState(state) {
        this.toggleAttribute('hidden', false);
        if (this.empty)   this.empty.hidden   = state !== 'empty';
        if (this.loading) this.loading.hidden  = state !== 'loading';
        if (this.grid)    this.grid.hidden     = state === 'empty';
      }

      async render() {
        const store = this._store();
        if (!store) return;

        const ids  = store.getIds();
        const meta = store.getMeta ? store.getMeta() : {};

        if (this.countEls) {
          this.countEls.forEach((el) => { el.textContent = ids.length ? '(' + ids.length + ')' : ''; });
        }

        // Remove cards que saíram da lista.
        this._cards.forEach((el, id) => {
          if (!ids.includes(id)) {
            el.remove();
            this._cards.delete(id);
          }
        });

        // Só dá pra renderizar itens que têm handle salvo.
        const renderable = ids.filter((id) => meta[id] && meta[id].handle);

        if (!ids.length || !renderable.length) {
          if (!this._cards.size) this._setState('empty');
          return;
        }

        const missing = renderable.filter((id) => !this._cards.has(id));
        if (missing.length && !this._cards.size) this._setState('loading');

        await Promise.all(missing.map((id) => this._fetchCard(id, meta[id])));

        // Reordena conforme a ordem da lista de desejos.
        renderable.forEach((id) => {
          const el = this._cards.get(id);
          if (el) this.grid.appendChild(el);
        });

        this._setState(this._cards.size ? 'list' : 'empty');
      }

      async _fetchCard(id, m) {
        if (this._cards.has(id)) return;
        try {
          const url = '/products/' + m.handle + '?section_id=' + this.cardSection;
          const res = await fetch(url);
          if (!res.ok) return;
          const html = await res.text();
          const tmp = document.createElement('div');
          tmp.innerHTML = html.trim();
          const card = tmp.querySelector('res-color-card') || tmp.firstElementChild;
          if (!card) return;
          const item = document.createElement('div');
          item.className = 'res-wl__item';
          item.appendChild(card);
          this._cards.set(id, item);
          this.grid.appendChild(item);
        } catch (e) {
          /* silencioso: item indisponível some da lista */
        }
      }
    }

    customElements.define('res-wishlist', ResWishlist);
  })();
</script>

{% schema %}
{
  "name": "Lista de desejos",
  "class": "RES__WISHLIST__V1",
  "settings": [
    {
      "type": "header",
      "content": "Conteúdo"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Meus favoritos"
    },
    {
      "type": "text",
      "id": "empty_text",
      "label": "Texto (lista vazia)",
      "default": "Você ainda não adicionou nenhum produto aos favoritos."
    },
    {
      "type": "text",
      "id": "empty_link_text",
      "label": "Texto do botão (lista vazia)",
      "default": "Explorar produtos"
    },
    {
      "type": "url",
      "id": "empty_link_url",
      "label": "Link do botão (lista vazia)"
    },
    {
      "type": "header",
      "content": "Cartão de Produto"
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Exibir botão no card",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "add_to_cart",
      "label": "Adicionar ao carrinho",
      "default": false,
      "visible_if": "{{ section.settings.show_button }}"
    },
    {
      "type": "checkbox",
      "id": "show_installments",
      "label": "Exibir parcelas",
      "default": true
    },
    {
      "type": "header",
      "content": "Grid"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Colunas (desktop)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "Colunas (tablet)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Colunas (mobile)",
      "min": 1,
      "max": 2,
      "step": 1,
      "default": 2
    },
    {
      "type": "header",
      "content": "Espaçamento"
    },
    {
      "type": "range",
      "id": "pad_top_mobile",
      "label": "Padding TOP (mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "pad_bottom_mobile",
      "label": "Padding BOTTOM (mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "pad_top_desktop",
      "label": "Padding TOP (desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "pad_bottom_desktop",
      "label": "Padding BOTTOM (desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Lista de desejos",
      "category": "Result"
    }
  ]
}
{% endschema %}
