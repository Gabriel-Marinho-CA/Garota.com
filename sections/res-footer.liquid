{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'res-footer.css' | asset_url | stylesheet_tag }}

{% style %}
  .{{ section.id }} {
    --res-ft-gap-desktop: {{ section.settings.column_gap_desktop }}px;
    --res-ft-gap-mobile: {{ section.settings.column_gap_mobile }}px;
    --res-ft-social-size-mobile: {{ section.settings.social_icon_size_mobile }}px;
    --res-ft-social-size-desktop: {{ section.settings.social_icon_size_desktop }}px;
    --res-ft-contact-size-mobile: {{ section.settings.contact_icon_size_mobile }}px;
    --res-ft-contact-size-desktop: {{ section.settings.contact_icon_size_desktop }}px;
    --res-ft-logo-width-mobile: {{ section.settings.logo_width_mobile }}px;
    --res-ft-logo-width-desktop: {{ section.settings.logo_width_desktop }}px;
    padding-top: {{ section.settings.pad_top_mobile }}px;
    padding-bottom: {{ section.settings.pad_bottom_mobile }}px;
  }

  .{{ section.id }} .res-ft__newsletter-heading {
    {% if section.settings.newsletter_heading_custom %}
      {% if section.settings.newsletter_heading_color != blank %}color: {{ section.settings.newsletter_heading_color }};{% endif %}
      font-weight: {{ section.settings.newsletter_heading_font_weight }};
      text-align: {{ section.settings.newsletter_heading_align }};
      font-size: {{ section.settings.newsletter_heading_font_size_mobile }}px;
    {% endif %}
  }

  .{{ section.id }} .res-ft__newsletter-subtitle {
    {% if section.settings.newsletter_subtitle_custom %}
      {% if section.settings.newsletter_subtitle_color != blank %}color: {{ section.settings.newsletter_subtitle_color }};{% endif %}
      font-weight: {{ section.settings.newsletter_subtitle_font_weight }};
      text-align: {{ section.settings.newsletter_subtitle_align }};
      font-size: {{ section.settings.newsletter_subtitle_font_size_mobile }}px;
    {% endif %}
  }

  .{{ section.id }} .res-ft__copyright {
    {% if section.settings.copyright_custom %}
      {% if section.settings.copyright_color != blank %}color: {{ section.settings.copyright_color }};{% endif %}
      font-weight: {{ section.settings.copyright_font_weight }};
      text-align: {{ section.settings.copyright_align }};
      font-size: {{ section.settings.copyright_font_size_mobile }}px;
    {% endif %}
  }

  @media screen and (min-width: 750px) {
    .{{ section.id }} {
      padding-top: {{ section.settings.pad_top_desktop }}px;
      padding-bottom: {{ section.settings.pad_bottom_desktop }}px;
    }

    .{{ section.id }} .res-ft__newsletter-heading {
      {% if section.settings.newsletter_heading_custom %}
        font-size: {{ section.settings.newsletter_heading_font_size_desktop }}px;
      {% endif %}
    }

    .{{ section.id }} .res-ft__newsletter-subtitle {
      {% if section.settings.newsletter_subtitle_custom %}
        font-size: {{ section.settings.newsletter_subtitle_font_size_desktop }}px;
      {% endif %}
    }

    .{{ section.id }} .res-ft__copyright {
      {% if section.settings.copyright_custom %}
        font-size: {{ section.settings.copyright_font_size_desktop }}px;
      {% endif %}
    }
  }
{% endstyle %}

<footer class="res-ft color-{{ section.settings.color_scheme }} {{ section.id }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
  <div class="res-ft__wrapper page-width">
    <div class="res-ft__top" style="--res-ft-column-gap-desktop: {{ section.settings.column_gap_desktop }}px;">
      <div class="res-ft__brand">
        {% if section.settings.logo != blank %}
          <a class="res-ft__logo" href="{{ routes.root_url }}">
            {{ section.settings.logo | image_url: width: 600 | image_tag: alt: shop.name, loading: 'lazy', class: 'res-ft__logo-img' }}
          </a>
        {% else %}
          <a class="res-ft__logo res-ft__logo--text" href="{{ routes.root_url }}">{{ shop.name }}</a>
        {% endif %}

        {% if section.settings.newsletter_enable %}
          <div class="res-ft__newsletter">
            {% if section.settings.newsletter_heading != blank %}
              <div class="res-ft__newsletter-heading rte">{{ section.settings.newsletter_heading }}</div>
            {% endif %}
            {% if section.settings.newsletter_subtitle != blank %}
              <div class="res-ft__newsletter-subtitle rte">{{ section.settings.newsletter_subtitle }}</div>
            {% endif %}

            {%- form 'customer', id: 'ResFooterNewsletter', class: 'res-ft__form newsletter-form' -%}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <div class="res-ft__form-field">
                <input
                  id="ResFooterNewsletter--{{ section.id }}"
                  type="email"
                  name="contact[email]"
                  class="res-ft__input"
                  value="{{ form.email }}"
                  aria-label="{{ section.settings.newsletter_placeholder | default: 'Seu endereço de email...' }}"
                  placeholder="{{ section.settings.newsletter_placeholder | default: 'Seu endereço de email...' }}"
                  autocorrect="off"
                  autocapitalize="off"
                  autocomplete="email"
                  required
                  {% if form.errors %}
                    autofocus
                    aria-invalid="true"
                  {% endif %}
                >
                <button
                  type="submit"
                  class="res-ft__submit"
                  name="commit"
                  aria-label="{{ 'newsletter.button_label' | t }}"
                >
                  {{- 'icon-arrow.svg' | inline_asset_content -}}
                </button>
              </div>
              {%- if form.errors -%}
                <small class="res-ft__form-message">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</small>
              {%- elsif form.posted_successfully? -%}
                <small class="res-ft__form-message res-ft__form-message--success">{{ 'newsletter.success' | t }}</small>
              {%- endif -%}
            {%- endform -%}
          </div>
        {% endif %}

        {% if section.settings.show_social %}
          <ul class="res-ft__social list-unstyled">
            {% if section.settings.social_whatsapp_link != blank %}
              <li>
                <a class="res-ft__social-link" href="{{ section.settings.social_whatsapp_link }}" aria-label="WhatsApp">
                  <span class="res-ft__social-icon">
                    {% if section.settings.social_whatsapp_icon != blank %}
                      {{ section.settings.social_whatsapp_icon | image_url: width: 100 | image_tag: alt: 'WhatsApp' }}
                    {% else %}
                      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2zm0 1.8c2.17 0 4.21.85 5.75 2.38a8.08 8.08 0 0 1 2.38 5.74c0 4.48-3.65 8.12-8.13 8.12h-.01c-1.48 0-2.93-.4-4.2-1.15l-.3-.18-3.11.82.83-3.04-.2-.31a8.05 8.05 0 0 1-1.24-4.3c0-4.48 3.64-8.12 8.13-8.12zm-4.5 4.32c-.21 0-.55.08-.84.39-.29.31-1.1 1.08-1.1 2.62s1.13 3.04 1.29 3.25c.16.21 2.22 3.39 5.38 4.75.75.32 1.34.51 1.79.66.75.24 1.44.2 1.98.12.6-.09 1.86-.76 2.12-1.5.26-.73.26-1.36.18-1.49-.08-.13-.29-.21-.6-.37-.31-.16-1.86-.92-2.15-1.02-.29-.11-.5-.16-.71.16-.21.31-.81 1.02-1 1.23-.18.21-.37.24-.68.08-.31-.16-1.32-.49-2.51-1.55-.93-.83-1.56-1.85-1.74-2.16-.18-.31-.02-.48.14-.63.14-.14.31-.37.47-.55.16-.18.21-.31.31-.52.1-.21.05-.39-.03-.55-.08-.16-.71-1.71-.97-2.34-.26-.61-.52-.53-.71-.54-.18-.01-.39-.01-.6-.01z"/></svg>
                    {% endif %}
                  </span>
                </a>
              </li>
            {% endif %}
            {% if section.settings.social_instagram_link != blank %}
              <li>
                <a class="res-ft__social-link" href="{{ section.settings.social_instagram_link }}" aria-label="Instagram">
                  <span class="res-ft__social-icon">
                    {% if section.settings.social_instagram_icon != blank %}
                      {{ section.settings.social_instagram_icon | image_url: width: 100 | image_tag: alt: 'Instagram' }}
                    {% else %}
                      {{ 'icon-instagram.svg' | inline_asset_content }}
                    {% endif %}
                  </span>
                </a>
              </li>
            {% endif %}
          </ul>
        {% endif %}
      </div>

      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'menu' %}
            <div class="res-ft__column" {{ block.shopify_attributes }}>
              {% if block.settings.heading != blank %}
                <div
                  class="res-ft__column-heading rte"
                  {% if block.settings.heading_custom %}
                    style="
                      {% if block.settings.heading_color != blank %}--res-ft-col-heading-color: {{ block.settings.heading_color }};{% endif %}
                      --res-ft-col-heading-weight: {{ block.settings.heading_font_weight }};
                      --res-ft-col-heading-align: {{ block.settings.heading_align }};
                      --res-ft-col-heading-size-mobile: {{ block.settings.heading_font_size_mobile }}px;
                      --res-ft-col-heading-size-desktop: {{ block.settings.heading_font_size_desktop }}px;
                    "
                  {% endif %}
                >
                  {{ block.settings.heading }}
                </div>
              {% endif %}
              {% if block.settings.menu != blank %}
                <ul class="res-ft__menu list-unstyled">
                  {% for link in block.settings.menu.links %}
                    <li>
                      <a class="res-ft__menu-link" href="{{ link.url }}">{{ link.title | escape }}</a>
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}
            </div>

          {% when 'contact' %}
            <div class="res-ft__column" {{ block.shopify_attributes }}>
              {% if block.settings.heading != blank %}
                <div
                  class="res-ft__column-heading rte"
                  {% if block.settings.heading_custom %}
                    style="
                      {% if block.settings.heading_color != blank %}--res-ft-col-heading-color: {{ block.settings.heading_color }};{% endif %}
                      --res-ft-col-heading-weight: {{ block.settings.heading_font_weight }};
                      --res-ft-col-heading-align: {{ block.settings.heading_align }};
                      --res-ft-col-heading-size-mobile: {{ block.settings.heading_font_size_mobile }}px;
                      --res-ft-col-heading-size-desktop: {{ block.settings.heading_font_size_desktop }}px;
                    "
                  {% endif %}
                >
                  {{ block.settings.heading }}
                </div>
              {% endif %}
              <ul class="res-ft__contact list-unstyled">
                {% for i in (1..3) %}
                  {% liquid
                    assign text_key = 'text_' | append: i
                    assign url_key = 'url_' | append: i
                    assign icon_key = 'icon_' | append: i
                    assign line_text = block.settings[text_key]
                    assign line_url = block.settings[url_key]
                    assign line_icon = block.settings[icon_key]
                  %}
                  {% if line_text != blank %}
                    <li class="res-ft__contact-row">
                      <span class="res-ft__contact-icon">
                        {% if line_icon != blank %}
                          {{ line_icon | image_url: width: 100 | image_tag: alt: '' }}
                        {% else %}
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15.5 5a5 5 0 0 1 3.5 3.5M15 1.5a8.5 8.5 0 0 1 7 7M21.5 16.92v2.7a1.5 1.5 0 0 1-1.63 1.5 14.8 14.8 0 0 1-6.46-2.3 14.6 14.6 0 0 1-4.5-4.5A14.8 14.8 0 0 1 6.6 4.85 1.5 1.5 0 0 1 8.1 3.2h2.7a1.5 1.5 0 0 1 1.5 1.29c.1.78.27 1.55.52 2.28a1.5 1.5 0 0 1-.34 1.58L11.6 9.1a12 12 0 0 0 4.5 4.5l.75-.87a1.5 1.5 0 0 1 1.58-.34c.73.25 1.5.42 2.28.52a1.5 1.5 0 0 1 1.29 1.5z"/></svg>
                        {% endif %}
                      </span>
                      {% if line_url != blank %}
                        <a class="res-ft__contact-text" href="{{ line_url }}">{{ line_text }}</a>
                      {% else %}
                        <span class="res-ft__contact-text">{{ line_text }}</span>
                      {% endif %}
                    </li>
                  {% endif %}
                {% endfor %}
              </ul>
            </div>
        {% endcase %}
      {% endfor %}
    </div>

    {% if section.settings.payment_enable %}
      <div class="res-ft__payment">
        <span class="visually-hidden">{{ 'sections.footer.payment' | t }}</span>
        <ul class="res-ft__payment-list list-unstyled" role="list">
          {% for type in shop.enabled_payment_types %}
            <li class="res-ft__payment-item">
              {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
            </li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}
  </div>

  <div class="res-ft__bottom">
    <div class="res-ft__bottom-wrapper page-width">
      <div class="res-ft__copyright rte">
        {% if section.settings.copyright_text != blank %}
          {{ section.settings.copyright_text }}
        {% else %}
          <small>&copy; {{ 'now' | date: '%Y' }}, {{ shop.name }}. Todos os direitos reservados</small>
        {% endif %}
      </div>

      {% if section.settings.tech_enable %}
        <div class="res-ft__tech">
          {% if section.settings.tech_label != blank %}
            <span class="res-ft__tech-label">{{ section.settings.tech_label }}</span>
          {% endif %}
          {% capture tech_content %}
            {% if section.settings.tech_logo != blank %}
              {{ section.settings.tech_logo | image_url: width: 300 | image_tag: alt: 'Tecnologia', class: 'res-ft__tech-logo-img' }}
            {% elsif section.settings.tech_text != blank %}
              <span class="res-ft__tech-text">{{ section.settings.tech_text }}</span>
            {% endif %}
          {% endcapture %}
          {% if tech_content != blank %}
            {% if section.settings.tech_link != blank %}
              <a class="res-ft__tech-logo" href="{{ section.settings.tech_link }}" target="_blank" rel="noopener">{{ tech_content }}</a>
            {% else %}
              <span class="res-ft__tech-logo">{{ tech_content }}</span>
            {% endif %}
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "res - Footer",
  "class": "RES__FOOTER__V1",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width_desktop",
      "label": "Largura do logo (desktop)",
      "min": 60,
      "max": 320,
      "step": 5,
      "unit": "px",
      "default": 150
    },
    {
      "type": "range",
      "id": "logo_width_mobile",
      "label": "Largura do logo (mobile)",
      "min": 60,
      "max": 280,
      "step": 5,
      "unit": "px",
      "default": 130
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "newsletter_enable",
      "label": "Exibir newsletter",
      "default": true
    },
    {
      "type": "richtext",
      "id": "newsletter_heading",
      "label": "Título",
      "default": "<p>SE INSCREVA EM NOSSA NEWSLETTER</p>"
    },
    { "type": "header", "content": "Personalização do título" },
    {
      "type": "checkbox",
      "id": "newsletter_heading_custom",
      "label": "Personalizar texto",
      "default": false
    },
    {
      "type": "color",
      "id": "newsletter_heading_color",
      "label": "Cor",
      "visible_if": "{{ section.settings.newsletter_heading_custom }}"
    },
    {
      "type": "range",
      "id": "newsletter_heading_font_size_desktop",
      "label": "Tamanho da fonte (desktop)",
      "min": 10,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 22,
      "visible_if": "{{ section.settings.newsletter_heading_custom }}"
    },
    {
      "type": "range",
      "id": "newsletter_heading_font_size_mobile",
      "label": "Tamanho da fonte (mobile)",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 18,
      "visible_if": "{{ section.settings.newsletter_heading_custom }}"
    },
    {
      "type": "select",
      "id": "newsletter_heading_font_weight",
      "label": "Peso da fonte",
      "default": "400",
      "options": [
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Médio (500)" },
        { "value": "600", "label": "Semi Bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ],
      "visible_if": "{{ section.settings.newsletter_heading_custom }}"
    },
    {
      "type": "select",
      "id": "newsletter_heading_align",
      "label": "Alinhamento",
      "default": "left",
      "options": [
        { "value": "left", "label": "Esquerda" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Direita" }
      ],
      "visible_if": "{{ section.settings.newsletter_heading_custom }}"
    },
    {
      "type": "richtext",
      "id": "newsletter_subtitle",
      "label": "Subtítulo",
      "default": "<p>E GANHE 10% OFF</p>"
    },
    { "type": "header", "content": "Personalização do subtítulo" },
    {
      "type": "checkbox",
      "id": "newsletter_subtitle_custom",
      "label": "Personalizar texto",
      "default": false
    },
    {
      "type": "color",
      "id": "newsletter_subtitle_color",
      "label": "Cor",
      "visible_if": "{{ section.settings.newsletter_subtitle_custom }}"
    },
    {
      "type": "range",
      "id": "newsletter_subtitle_font_size_desktop",
      "label": "Tamanho da fonte (desktop)",
      "min": 10,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 13,
      "visible_if": "{{ section.settings.newsletter_subtitle_custom }}"
    },
    {
      "type": "range",
      "id": "newsletter_subtitle_font_size_mobile",
      "label": "Tamanho da fonte (mobile)",
      "min": 10,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 12,
      "visible_if": "{{ section.settings.newsletter_subtitle_custom }}"
    },
    {
      "type": "select",
      "id": "newsletter_subtitle_font_weight",
      "label": "Peso da fonte",
      "default": "400",
      "options": [
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Médio (500)" },
        { "value": "600", "label": "Semi Bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ],
      "visible_if": "{{ section.settings.newsletter_subtitle_custom }}"
    },
    {
      "type": "select",
      "id": "newsletter_subtitle_align",
      "label": "Alinhamento",
      "default": "left",
      "options": [
        { "value": "left", "label": "Esquerda" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Direita" }
      ],
      "visible_if": "{{ section.settings.newsletter_subtitle_custom }}"
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Placeholder do campo",
      "default": "Seu endereço de email..."
    },
    {
      "type": "header",
      "content": "Redes sociais"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Exibir redes sociais",
      "default": true
    },
    {
      "type": "url",
      "id": "social_whatsapp_link",
      "label": "Link do WhatsApp"
    },
    {
      "type": "image_picker",
      "id": "social_whatsapp_icon",
      "label": "Ícone do WhatsApp personalizado",
      "info": "Se vazio, usa o ícone padrão."
    },
    {
      "type": "url",
      "id": "social_instagram_link",
      "label": "Link do Instagram"
    },
    {
      "type": "image_picker",
      "id": "social_instagram_icon",
      "label": "Ícone do Instagram personalizado",
      "info": "Se vazio, usa o ícone padrão."
    },
    {
      "type": "range",
      "id": "social_icon_size_desktop",
      "label": "Tamanho dos ícones (desktop)",
      "min": 12,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "social_icon_size_mobile",
      "label": "Tamanho dos ícones (mobile)",
      "min": 12,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "header",
      "content": "Ícones de contato"
    },
    {
      "type": "range",
      "id": "contact_icon_size_desktop",
      "label": "Tamanho dos ícones (desktop)",
      "min": 10,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "contact_icon_size_mobile",
      "label": "Tamanho dos ícones (mobile)",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Meios de pagamento"
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "label": "Exibir ícones de pagamento",
      "default": true
    },
    {
      "type": "header",
      "content": "Rodapé inferior"
    },
    {
      "type": "richtext",
      "id": "copyright_text",
      "label": "Texto de copyright",
      "default": "<p>Copyright garota.com - 48.751.501/0001-36 - 2026. Todos os direitos reservados</p>"
    },
    { "type": "header", "content": "Personalização do copyright" },
    {
      "type": "checkbox",
      "id": "copyright_custom",
      "label": "Personalizar texto",
      "default": false
    },
    {
      "type": "color",
      "id": "copyright_color",
      "label": "Cor",
      "visible_if": "{{ section.settings.copyright_custom }}"
    },
    {
      "type": "range",
      "id": "copyright_font_size_desktop",
      "label": "Tamanho da fonte (desktop)",
      "min": 8,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 12,
      "visible_if": "{{ section.settings.copyright_custom }}"
    },
    {
      "type": "range",
      "id": "copyright_font_size_mobile",
      "label": "Tamanho da fonte (mobile)",
      "min": 8,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 11,
      "visible_if": "{{ section.settings.copyright_custom }}"
    },
    {
      "type": "select",
      "id": "copyright_font_weight",
      "label": "Peso da fonte",
      "default": "400",
      "options": [
        { "value": "400", "label": "Regular (400)" },
