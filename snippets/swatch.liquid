{% comment %}
  Renders a swatch component.
  Accepts:
  - swatch: {Object} a swatch object
  - shape: {String} swatch shape. Accepts 'square', defaults to circle.
  - color_name: {String} raw color name used to generate tp-swatch--{slug} class (optional)

  Usage:
  {% render 'swatch',
    swatch: value.swatch,
    shape: 'square',
    color_name: value
  %}
{% endcomment %}

{%- liquid
  assign swatch_value = null
  if swatch.image
    assign image_url = swatch.image | image_url: width: 50
    assign swatch_value = 'url(' | append: image_url | append: ')'
    assign swatch_focal_point = swatch.image.presentation.focal_point
  elsif swatch.color
    assign swatch_value = 'rgb(' | append: swatch.color.rgb | append: ')'
  endif

  assign tp_slug = ''
  if color_name != blank
    assign tp_slug = color_name | downcase | replace: 'á', 'a' | replace: 'à', 'a' | replace: 'ã', 'a' | replace: 'â', 'a' | replace: 'é', 'e' | replace: 'ê', 'e' | replace: 'í', 'i' | replace: 'ó', 'o' | replace: 'ô', 'o' | replace: 'õ', 'o' | replace: 'ú', 'u' | replace: 'ü', 'u' | replace: 'ç', 'c' | replace: ' ', '-' | replace: '_', '-' | replace: '/', '-'
  endif
-%}

<span
  {% if swatch_value %}
    class="swatch{% if shape == 'square' %} swatch--square{% endif %}{% if tp_slug != '' %} tp-swatch--{{ tp_slug }}{% endif %}"
    style="--swatch--background: {{ swatch_value }};{% if swatch_focal_point %} --swatch-focal-point: {{ swatch_focal_point }};{% endif %}"
  {% else %}
    class="swatch{% if tp_slug == '' %} swatch--unavailable{% endif %}{% if shape == 'square' %} swatch--square{% endif %}{% if tp_slug != '' %} tp-swatch--{{ tp_slug }}{% endif %}"
  {% endif %}
></span>
