{%- liquid
  assign res_color_option_index = null
  for opt in res_product.options
    assign opt_lower = opt | downcase
    if opt_lower == 'cor' or opt_lower == 'color' or opt_lower == 'colour' or opt_lower == 'cores'
      assign res_color_option_index = forloop.index0
      break
    endif
  endfor
  if res_color_option_index == null
    assign res_color_option_index = 0
  endif

  assign res_size_option_index = -1
  for opt in res_product.options
    assign opt_lower = opt | downcase
    if opt_lower == 'tamanho' or opt_lower == 'size' or opt_lower == 'sizes' or opt_lower == 'tam'
      assign res_size_option_index = forloop.index0
      break
    endif
  endfor

  assign res_color_values = res_product.options_with_values[res_color_option_index].values
-%}

<res-color-card class="res-card">
  {%- comment -%} Imagem {%- endcomment -%}
  <div class="res-card__media-wrapper">
    {% if res_product.compare_at_price > res_product.price %}
      <div class="res-card__badges">
        <span class="res-card__badge">OFERTA</span>
      </div>
    {% endif %}
    <wishlist-button  product-id="{{ res_product.selected_or_first_available_variant.id }}"class="res-card__wishlist" aria-label="Adicionar aos favoritos" type="button">
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
    </wishlist-button>

    <a href="{{ res_product.url }}" class="res-card__media-link" aria-label="{{ res_product.title | escape }}">
      <div class="res-card__media">
        <div class="swiper res-card__swiper">
          <div class="swiper-wrapper">
            <div class="swiper-slide">
              {% if res_product.featured_image %}
                {{
                  res_product.featured_image
                  | image_url: width: 800
                  | image_tag:
                    loading: 'lazy',
                    class: 'res-card__img',
                    widths: '400, 600, 800',
                    sizes: '(min-width: 1024px) 25vw, (min-width: 750px) 33vw, 50vw'
                }}
              {% else %}
                {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg res-card__img' }}
              {% endif %}
            </div>
          </div>
        </div>

        {%- comment -%} Arrows — visíveis no hover {%- endcomment -%}
        {% if res_product.images.size > 1 %}
          <button class="res-card__nav res-card__nav--prev" aria-label="Anterior" tabindex="-1" type="button">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button class="res-card__nav res-card__nav--next" aria-label="Próximo" tabindex="-1" type="button">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        {% endif %}
      </div>
    </a>

    {%- comment -%} Indicador de imagens (barrinhas) {%- endcomment -%}
    {% if res_product.images.size > 1 %}
      <div class="res-card__img-dots swiper-pagination"></div>
    {% endif %}
  </div>

  {%- comment -%} Info {%- endcomment -%}
  <div class="res-card__info">
    <div class="res-card__info-grid">
      <div class="res-card__col-left">
        <a href="{{ res_product.url }}" class="res-card__title-link">
          <h3 class="res-card__title">{{ res_product.title | escape }}</h3>
        </a>

        {% if res_size_option_index >= 0 %}
          <div class="res-card__sizes-section">
            <span class="res-card__variants-label">TAMANHOS</span>
            <div class="res-card__buy-sizes"></div>
          </div>
        {% endif %}
      </div>

      <div class="res-card__col-right">
        <a href="{{ res_product.url }}" class="res-card__price-link">
          {% if show_price %}
            <div class="res-card__price">
              <span class="res-card__regular-price">{{ res_product.price | money_with_currency | remove: 'BRL' }}</span>
              {% if res_product.compare_at_price > res_product.price %}
                <s class="res-card__compare-price">
                  {{- res_product.compare_at_price | money_with_currency | remove: 'BRL' -}}
                </s>
              {% endif %}
              {% if show_installments %}
                <div class="res-card__installments-wrap">
                  {% render 'res-installments', tp_price: res_product.price %}
                </div>
              {% endif %}
            </div>
          {% endif %}
        </a>

        {% if res_color_values.size > 1 %}
          <div class="res-card__colors-section">
            <span class="res-card__variants-label">CORES</span>
            <div class="res-card__swatches">
              {% for color_value in res_color_values %}
                {%- liquid
                  assign swatch_slug = color_value | downcase | replace: 'á', 'a' | replace: 'à', 'a' | replace: 'ã', 'a' | replace: 'â', 'a' | replace: 'é', 'e' | replace: 'ê', 'e' | replace: 'í', 'i' | replace: 'ó', 'o' | replace: 'ô', 'o' | replace: 'õ', 'o' | replace: 'ú', 'u' | replace: 'ü', 'u' | replace: 'ç', 'c' | replace: ' ', '-' | replace: '_', '-' | replace: '/', '-'
                -%}
                <button
                  class="res-card__swatch tp-swatch--{{ swatch_slug }}{% if forloop.first %} res-card__swatch--active{% endif %}"
                  data-color="{{ color_value | escape }}"
                  aria-label="{{ color_value | escape }}"
                  title="{{ color_value | escape }}"
                  type="button"
                ></button>
              {% endfor %}
            </div>
          </div>
        {% endif %}
      </div>
    </div>

    {%- comment -%}
      product-form (Dawn web component) — renderizado sempre que show_button=true.
      O JS do ResColorCard atualiza o input[name="id"] conforme cor/tamanho selecionado.
    {%- endcomment -%}
    {% if show_button %}
      {%- assign res_form_id = 'res-form-' | append: section.id | append: '-' | append: res_product.id -%}
      {% if res_product.available %}
        <product-form data-section-id="{{ section.id }}">
          {%- form 'product',
            res_product,
            id: res_form_id,
            class: 'res-card__form form',
            novalidate: 'novalidate',
            data-type: 'add-to-cart-form'
          -%}
            <input
              type="hidden"
              name="id"
              value="{{ res_product.selected_or_first_available_variant.id }}"
              class="product-variant-id"
            >
            <button
              id="{{ res_form_id }}-submit"
              type="submit"
              name="add"
              class="quick-add__submit res-card__btn button button--full-width button--secondary{% if horizontal_quick_add %} card--horizontal__quick-add{% endif %}"
              aria-haspopup="dialog"
              aria-labelledby="{{ product_form_id }}-submit title-{{ section_id }}-{{ card_product.id }}"
              aria-live="polite"
              data-sold-out-message="true"
              {% if card_product.selected_or_first_available_variant.available == false %}
                disabled
              {% endif %}
            >
              <span>ADICIONAR À SACOLA</span>
              {%- render 'loading-spinner' -%}
            </button>
          {%- endform -%}
        </product-form>
      {% else %}
        <button class="res-card__btn res-card__btn--disabled" type="button" disabled aria-disabled="true">
          ESGOTADO
        </button>
      {% endif %}
    {% endif %}
  </div>

  {%- comment -%} Dados de variantes/imagens para o JS {%- endcomment -%}
  <script type="application/json" class="res-card__data">
    {
      "productUrl": {{ res_product.url | json }},
      "colorOptionIndex": {{ res_color_option_index }},
      "sizeOptionIndex": {{ res_size_option_index }},
      "colorValues": {{ res_color_values | json }},
      "variants": [
        {%- for variant in res_product.variants -%}
          {%- unless forloop.first -%},{%- endunless -%}
          {"id":{{ variant.id }},"options":{{ variant.options | json }},"available":{{ variant.available }}}
        {%- endfor -%}
      ],
      "images": [
        {%- for image in res_product.images -%}
          {%- unless forloop.first -%},{%- endunless -%}
          {"src":{{ image | image_url: width: 800 | json }},"alt":{{ image.alt | json }},"width":{{ image.width }},"height":{{ image.height }}}
        {%- endfor -%}
      ]
    }
  </script>
</res-color-card>
